# === 한국투자증권 KIS Open API ===
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=your_account_number_here
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# === 키움증권 API ===
KIWOOM_APP_KEY=your_kiwoom_app_key_here
KIWOOM_SECRET_KEY=your_kiwoom_secret_key_here
KIWOOM_ACCOUNT_NO=your_kiwoom_account_here
KIWOOM_BASE_URL=https://mockapi.kiwoom.com

# === NH투자증권 API (QV Open API - Windows COM only, REST 미지원) ===
NH_APP_KEY=your_nh_app_key_here
NH_APP_SECRET=your_nh_app_secret_here
NH_ACCOUNT_NO=your_nh_account_here

# === 공통 설정 ===
TRADING_MODE=paper
